# Session Manager — Token Configuration
# Copy this file to .env and fill in your actual API keys.
# The manager loads SESSION_TOKEN_1 through SESSION_TOKEN_N in order.
# Add or remove lines freely; the number suffix must be consecutive from 1.

SESSION_TOKEN_1=sk-ant-api03-REPLACE_WITH_REAL_TOKEN_1
SESSION_TOKEN_2=sk-ant-api03-REPLACE_WITH_REAL_TOKEN_2
SESSION_TOKEN_3=sk-ant-api03-REPLACE_WITH_REAL_TOKEN_3
SESSION_TOKEN_4=sk-ant-api03-REPLACE_WITH_REAL_TOKEN_4
SESSION_TOKEN_5=sk-ant-api03-REPLACE_WITH_REAL_TOKEN_5

# Optional overrides
# CLI_COMMAND=claude          # binary to launch (default: claude)
# CLI_ARGS=--no-color         # extra flags passed to the CLI (space-separated)
# DEBUG=1                     # enable verbose debug logging
